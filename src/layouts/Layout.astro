---
import "~/styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
const { title, description } = Astro.props;
import { siteLang, siteName, themeColor, siteDomain, phone, address, siteSlogan } from "~/data/config";

const canonicalURL = new URL(Astro.url.pathname, Astro.site || `https://${siteDomain}`);
const pageTitle = title ? `${title} | ${siteName}` : siteName;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": siteName,
	"description": siteSlogan,
	"url": `https://${siteDomain}`,
	"telephone": phone.label,
	"address": {
		"@type": "PostalAddress",
		"addressLocality": address.city,
		"addressRegion": address.state,
		"addressCountry": "HU",
	},
};
---

<!doctype html>
<html lang={siteLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content={themeColor} />
		<meta name="description" content={description} />
		<meta name="robots" content="index,follow" />
		<meta name="googlebot" content="index,follow" />
		<link rel="canonical" href={canonicalURL.href} />
		<link rel="author" href="humans.txt" />

		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content={siteLang} />

		<title>{pageTitle}</title>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<ClientRouter />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
